{
  "name": "qa-cicd-practice",
  "version": "1.0.0",
  "description": "QA Automation Practice Project – CI/CD Pipeline with automated testing",
  "main": "app/server.js",
  "scripts": {
    "start": "node app/server.js",
    "test": "jest --forceExit --runInBand",
    "test:unit": "jest tests/unit --forceExit --runInBand --verbose",
    "test:integration": "jest tests/integration --forceExit --runInBand --verbose",
    "test:e2e": "jest tests/e2e --forceExit --runInBand --verbose --testTimeout=20000",
    "test:coverage": "jest --coverage --forceExit --runInBand",
    "test:ci": "jest --forceExit --runInBand --ci --reporters=default",
    "test:web": "playwright test",
    "test:web:headed": "playwright test --headed",
    "test:web:report": "playwright show-report playwright-report"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/webautomation/"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "collectCoverageFrom": [
      "app/**/*.js",
      "!app/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 70
      }
    },
    "testTimeout": 15000
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
